# ─────────────────────────────────────────────────────────────
# Neighborhood Library Service — environment configuration
# Copy to `.env` and adjust. NEVER commit the real `.env`.
# ─────────────────────────────────────────────────────────────

# ── PostgreSQL ──
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=library
POSTGRES_USER=library_app
POSTGRES_PASSWORD=library_dev_pw
# Async URL used by the app (SQLAlchemy + asyncpg)
DATABASE_URL=postgresql+asyncpg://library_app:library_dev_pw@localhost:5432/library

# ── Auth / JWT ──
JWT_SECRET=dev_only_change_me_to_a_long_random_string
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=1209600
ARGON2_TIME_COST=3

# ── Servers ──
GRPC_PORT=50051
REST_PORT=8000
CORS_ORIGINS=http://localhost:3000
RATE_LIMIT_LOGIN_PER_MINUTE=5

# ── Lending policy ──
LOAN_PERIOD_DAYS=14
FINE_PER_DAY=0.25

# ── App ──
ENV=development
LOG_LEVEL=INFO

# ── Frontend (Next.js) ──
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
